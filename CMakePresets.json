{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_CORE": "OFF",
        "BUILD_UI": "OFF",
        "BUILD_UTILS": "OFF"
      }
    }, 
    {
      "name": "linux-release",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "description": "Linux Release Build with all Modules",
      "binaryDir": "${sourceDir}/build/linux-release",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_CORE": "ON",
        "BUILD_UI": "ON",
        "BUILD_UTILS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "description": "Linux Debug Build",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CORE": "ON",
        "BUILD_UI": "ON",
        "BUILD_UTILS": "ON",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-debug-core",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "description": "Linux Debug Build Core only",
      "binaryDir": "${sourceDir}/build/linux-debug-core",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CORE": "ON",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-debug-ui",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "description": "Linux Debug Build UserInterface only",
      "binaryDir": "${sourceDir}/build/linux-debug-ui",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_UI": "ON",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }, 
    {
      "name": "macos-base",
      "inherits": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "BUILD_UTILS": "ON"
      }
    },
    {
      "name": "macos-release",
      "inherits": "macos-base",
      "description": "macOS Release Build with all Modules",
      "binaryDir": "${sourceDir}/build/macos-release",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_CORE": "ON",
        "BUILD_UI": "ON"
      }
    },
    {
      "name": "macos-debug",
      "inherits": "macos-base",
      "description": "macOS Debug Build",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CORE": "ON",
        "BUILD_UI": "ON",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      }
    },
    {
      "name": "macos-debug-core",
      "inherits": "macos-base",
      "description": "macOS Debug Build Core only",
      "binaryDir": "${sourceDir}/build/macos-debug-core",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CORE": "ON",
        "BUILD_UI": "OFF",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      }
    },
    {
      "name": "macos-debug-ui",
      "inherits": "macos-base",
      "description": "macOS Debug Build UserInterface only",
      "binaryDir": "${sourceDir}/build/macos-debug-ui",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CORE": "OFF",
        "BUILD_UI": "ON",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      }
    }, 
    {
      "name": "windows-base",
      "inherits": "base",
      "hidden": true,  
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "BUILD_UTILS": "ON",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "windows-release",
      "inherits": "windows-base",
      "description": "Windows Release Build with all Modules",
      "binaryDir": "${sourceDir}/build/windows-release",
      "hidden": false,
      "cacheVariables": {
        "BUILD_CORE": "ON",
        "BUILD_UI": "ON"
      }
    },
    {
      "name": "windows-debug",
      "inherits": "windows-base",
      "description": "Windows Debug Build",
      "binaryDir": "${sourceDir}/build/windows-debug",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CORE": "ON",
        "BUILD_UI": "ON",
        "CMAKE_CXX_FLAGS": "/W3 /Zi"
      }
    },
    {
      "name": "windows-debug-core",
      "inherits": "windows-base",
      "description": "Windows Debug Build Core only",
      "binaryDir": "${sourceDir}/build/windows-debug-core",
      "hidden": false,
      "cacheVariables": {
        "BUILD_CORE": "ON",
        "BUILD_UI": "OFF",
        "CMAKE_CXX_FLAGS": "/W3"
      }
    },
    {
      "name": "windows-debug-ui",
      "inherits": "windows-base",
      "description": "Windows Debug Build UserInterface only",
      "binaryDir": "${sourceDir}/build/windows-debug-ui",
      "hidden": false,
      "cacheVariables": {
        "BUILD_CORE": "OFF",
        "BUILD_UI": "ON",
        "CMAKE_CXX_FLAGS": "/W3"
      }
    },
    {
      "name": "linux-debug-tests",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "description": "Linux Debug Build Tests only",
      "binaryDir": "${sourceDir}/build/linux-debug-tests",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "CMAKE_CXX_FLAGS": "-Wpedantic"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-debug-tests",
      "inherits": "windows-base",
      "description": "Windows Debug Build Tests only",
      "binaryDir": "${sourceDir}/build/windows-debug-tests",
      "hidden": false,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "CMAKE_CXX_FLAGS": "/W3 /Zi",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebug"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "linux-debug-core",
      "configurePreset": "linux-debug-core",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "linux-debug-ui",
      "configurePreset": "linux-debug-ui",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "cleanFirst": true
    },

   
    {
      "name": "macos-debug-core",
      "configurePreset": "macos-debug-core",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "macos-debug-ui",
      "configurePreset": "macos-debug-ui",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release",
      "cleanFirst": true
    },

    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug",
      "cleanFirst": true
    },
    {
      "name": "windows-debug-core",
      "configurePreset": "windows-debug-core",
      "configuration": "Debug",
      "cleanFirst": true
    },
    {
      "name": "windows-debug-ui",
      "configurePreset": "windows-debug-ui",
      "configuration": "Debug",
      "cleanFirst": true
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release",
      "cleanFirst": true
    },

    {
      "name": "linux-debug-tests",
      "configurePreset": "linux-debug-tests",
      "cleanFirst": true,
      "environment": { "VERBOSE": "1" }
    },
    {
      "name": "windows-debug-tests",
      "configurePreset": "windows-debug-tests",
      "configuration": "Debug",
      "cleanFirst": true
    }
  ]
}

